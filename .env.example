# PayOS Credentials
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here

# Gmail SMTP Credentials
# NOTE: For Gmail, use a 16-character App Password, NOT your regular password.
# Enable 2-Step Verification first, then generate an App Password.
SPRING_MAIL_USERNAME=your_gmail_username@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password_here
